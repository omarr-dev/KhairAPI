{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=khair_db;Username=postgres;Password=your_password_here;Pooling=true;Minimum Pool Size=5;Maximum Pool Size=100;Connection Idle Lifetime=300"
  },
  "JwtSettings": {
    "SecretKey": "YourSecretKeyHere_MustBe32CharactersOrMore_ChangeThisInProduction",
    "Issuer": "KhairAPI",
    "Audience": "KhairFrontend",
    "ExpirationMinutes": 1440,
    "RefreshTokenExpirationDays": 7
  },
  "Sentry": {
    "Dsn": "https://your-key@oXXXX.ingest.de.sentry.io/XXXX",
    "SendDefaultPii": false,
    "TracesSampleRate": 0.1,
    "MaxRequestBodySize": "Always"
  }
}


